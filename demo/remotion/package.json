{
  "name": "hackathon-demo-remotion",
  "version": "0.1.0",
  "private": true,
  "description": "Remotion workspace for the 120-second hackathon product demo",
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion bundle src/index.ts --out-dir build",
    "render": "remotion render src/index.ts DemoMaster out/demo-master.mp4 --codec=h264 --audio-codec=aac --pixel-format=yuv420p"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.280"
  },
  "devDependencies": {
    "@remotion/cli": "^4.0.280",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  }
}
